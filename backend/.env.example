# ─────────────────────────────────────────────────────────────
#  AI Pulse — Configuration Template
#  Copy this file to .env and fill in your actual API keys.
#  Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────
# Primary provider: "ollama" | "groq" | "openai"
# Recommended for cloud/server: groq (free tier, fast)
# Recommended for local dev:    ollama (no cost, no rate limits)
LLM_PROVIDER=groq

# ── LLM Models ───────────────────────────────────────────────
LLM_MODEL=qwen2.5:7b
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini

# ── API Keys ──────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (free tier) — https://console.groq.com/keys
GROQ_API_KEY=

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ── News Sources ──────────────────────────────────────────────
# NewsAPI.org (free tier) — https://newsapi.org/account
NEWS_API_KEY=

# SerpAPI — optional, adds Google News results
SERPAPI_KEY=

# GitHub token — optional, raises rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# ── Pipeline Settings ─────────────────────────────────────────
FETCH_INTERVAL_MINUTES=10
DB_PATH=news.db

# Minimum raw articles from Wave 1 (NewsAPI+arXiv) before activating
# secondary sources (Reddit, GitHub, SerpAPI)
MIN_ARTICLES_THRESHOLD=10

# ── Debug Mode ────────────────────────────────────────────────
# Set to "true" for verbose per-source and per-provider logging
DEBUG=false
